{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "A calendar event created by a user.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the event."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the event."
        },
        "time": {
          "type": "string",
          "description": "The time of the event (e.g., HH:mm)."
        },
        "date": {
          "type": "string",
          "description": "The date of the event (ISO 8601 format: YYYY-MM-DD)."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the event."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the event was created."
        }
      },
      "required": ["title", "date", "userId"]
    }
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Collection of user events."
    }
  }
}
