// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: events
// Document ID: auto-generated
// Fields:
//   - title: string (required, minLen 1, maxLen 100)
//   - description: string (optional, maxLen 500)
//   - time: string (optional, HH:mm format)
//   - date: string (required, YYYY-MM-DD format)
//   - userId: string (required, must match request.auth.uid)
//   - createdAt: timestamp (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             (!('time' in data) || (data.time is string && data.time.matches("^\\d{2}:\\d{2}$")));
    }

    match /events/{eventId} {
      // Users can only read their own events
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can only create events for themselves
      allow create: if isAuthenticated() && isValidEvent(request.resource.data);
      
      // Users can only update their own events
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                     isValidEvent(request.resource.data) &&
                     request.resource.data.userId == resource.data.userId; // userId is immutable
      
      // Users can only delete their own events
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      // Basic user profile protection
      allow read, write: if isOwner(userId);
    }
  }
}
